                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 * Proyecto 1 Progra Micros
                                 *
                                 * Creado: 27-02-2026
                                 * Autor : Joaquín Fuentes
                                 * Descripción: Reloj digital con alarma, fecha y configuración
                                 *              de hora/fecha/alarma mediante 4 botones.
                                 *
                                 * PINES:
                                 *   PC0 = B1 - Cambiar modo
                                 *   PC1 = B2 - UP  (incrementar)
                                 *   PC2 = B3 - DOWN (decrementar)
                                 *   PC3 = B4 - SELECT (alternar horas<->minutos / día<->mes)
                                 *   PC4 = LED indicador modo configuración
                                 *   PC5 = LED indicador alarma activa
                                 *
                                 * MODOS:
                                 *   MODE 0 = Display Hora  (HH:MM)
                                 *   MODE 1 = Display Fecha (DD/MM)
                                 *   MODE 2 = Config Hora
                                 *   MODE 3 = Config Fecha
                                 *   MODE 4 = Config Alarma
                                 *   MODE 5 = Apagar Alarma -> regresa a MODE 0
                                 */
                                 /****************************************/
                                 .include "M328PDEF.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 .dseg
                                 .org SRAM_START
                                 
000100                           DIGIT_INDEX:        .byte 1
000101                           DIG0:               .byte 1
000102                           DIG1:               .byte 1
000103                           DIG2:               .byte 1
000104                           DIG3:               .byte 1
000105                           MILISEC_L:          .byte 1
000106                           MILISEC_H:          .byte 1
000107                           SECS:               .byte 1
000108                           MINS:               .byte 1
000109                           HOURS:              .byte 1
00010a                           DAY:                .byte 1
00010b                           MONTH:              .byte 1
00010c                           ALARM_MIN:          .byte 1
00010d                           ALARM_HOUR:         .byte 1
00010e                           ALARM_ON:           .byte 1     ; 1 = alarma configurada y activa
00010f                           BUZZER_ON:          .byte 1     ; 1 = buzzer sonando
000110                           FLAG_1S:            .byte 1
000111                           FLAG_500MS:         .byte 1
000112                           FLAG_BTN_UP:        .byte 1     ; PC1 confirmado
000113                           FLAG_BTN_DOWN:      .byte 1     ; PC2 confirmado
000114                           FLAG_BTN_SEL:       .byte 1     ; PC3 confirmado
000115                           DEBOUNCE_COUNT_0:   .byte 1
000116                           DEBOUNCE_COUNT_1:   .byte 1
000117                           DEBOUNCE_COUNT_2:   .byte 1
000118                           DEBOUNCE_COUNT_3:   .byte 1
000119                           FLAG_DEBOUNCE_0:    .byte 1     ; PC0
00011a                           FLAG_DEBOUNCE_1:    .byte 1     ; PC1
00011b                           FLAG_DEBOUNCE_2:    .byte 1     ; PC2
00011c                           FLAG_DEBOUNCE_3:    .byte 1     ; PC3
00011d                           CONFIG_SUB:         .byte 1     ; 0=horas/día, 1=minutos/mes
00011e                           BLINK_HIDE:         .byte 1     ; 1=ocultar dígito activo (parpadeo config)
                                 
                                 ; Días máximos por mes en flash (ver tabla_dias_mes en cseg)
                                 
                                 .equ MAX_DIG    = 4
                                 .equ MAX_MODES  = 6
                                 
                                 .def MODE       = R23
                                 .def FLAG_PC0   = R21
                                 .def FLAG_PC1   = R22
                                 .def FLAG_PC2   = R20
                                 .def FLAG_PC3   = R19
                                 
                                 /****************************************/
                                 .cseg
                                 .org 0x0000
000000 c01c                          RJMP RESET
                                 
                                 .org PCI1addr
000008 c422                          RJMP PCINT8_ISR
                                 
                                 .org OC0Aaddr
00001c c338                          RJMP TIMER_ISR
                                 
                                 /****************************************/
                                 RESET:
00001d ef0f                          LDI R16, LOW(RAMEND)
00001e bf0d                          OUT SPL, R16
00001f e008                          LDI R16, HIGH(RAMEND)
000020 bf0e                          OUT SPH, R16
                                 
                                 SETUP:
000021 2411                          CLR R1
                                 
000022 e000                          LDI R16, 0
000023 9300 0100                     STS DIGIT_INDEX,     R16
000025 9300 0105                     STS MILISEC_L,       R16
000027 9300 0106                     STS MILISEC_H,       R16
000029 9300 0101                     STS DIG0,            R16
00002b 9300 0102                     STS DIG1,            R16
00002d 9300 0103                     STS DIG2,            R16
00002f 9300 0104                     STS DIG3,            R16
000031 9300 0107                     STS SECS,            R16
000033 9300 0108                     STS MINS,            R16
000035 9300 0109                     STS HOURS,           R16
000037 9300 010c                     STS ALARM_MIN,       R16
000039 9300 010d                     STS ALARM_HOUR,      R16
00003b 9300 010e                     STS ALARM_ON,        R16
00003d 9300 010f                     STS BUZZER_ON,       R16
00003f 9300 0112                     STS FLAG_BTN_UP,     R16
000041 9300 0113                     STS FLAG_BTN_DOWN,   R16
000043 9300 0114                     STS FLAG_BTN_SEL,    R16
000045 9300 0119                     STS FLAG_DEBOUNCE_0, R16
000047 9300 011a                     STS FLAG_DEBOUNCE_1, R16
000049 9300 011b                     STS FLAG_DEBOUNCE_2, R16
00004b 9300 011c                     STS FLAG_DEBOUNCE_3, R16
00004d 9300 0115                     STS DEBOUNCE_COUNT_0,R16
00004f 9300 0116                     STS DEBOUNCE_COUNT_1,R16
000051 9300 0117                     STS DEBOUNCE_COUNT_2,R16
000053 9300 0118                     STS DEBOUNCE_COUNT_3,R16
000055 9300 011d                     STS CONFIG_SUB,      R16
000057 9300 011e                     STS BLINK_HIDE,      R16
                                 
                                     ; Fecha inicial 01/01
000059 e001                          LDI R16, 1
00005a 9300 010a                     STS DAY,   R16
00005c 9300 010b                     STS MONTH, R16
                                 
                                     ; PC0-PC3 entradas, PC4-PC5 salidas (LEDs)
00005e e300                          LDI R16, (1<<PC4)|(1<<PC5)
00005f b907                          OUT DDRC, R16
                                 
                                     ; Pull-ups en PC0-PC3
000060 e00f                          LDI R16, (1<<PC0)|(1<<PC1)|(1<<PC2)|(1<<PC3)
000061 b908                          OUT PORTC, R16
                                 
                                     ; Habilitar PCINT grupo 1
000062 e002                          LDI R16, (1<<PCIE1)
000063 9300 0068                     STS PCICR, R16
                                 
                                     ; Habilitar PCINT8-PCINT11 (PC0-PC3)
000065 e00f                          LDI R16, (1<<PCINT8)|(1<<PCINT9)|(1<<PCINT10)|(1<<PCINT11)
000066 9300 006c                     STS PCMSK1, R16
                                 
                                     ; PORTD = segmentos salida
000068 ef0f                          LDI R16, 0b11111111
000069 b90a                          OUT DDRD, R16
                                 
                                     ; PORTB bits 0-3 = transistores dígitos, bits 4-5 = LEDs segundos
00006a e30f                          LDI R16, 0b00111111
00006b b904                          OUT DDRB, R16
                                 
00006c 2700                          CLR R16
00006d b90b                          OUT PORTD, R16
00006e b905                          OUT PORTB, R16
                                 
                                     ; Timer0 CTC 1ms (16MHz, prescaler 64, OCR0A=249)
00006f e002                          LDI R16, (1<<WGM01)
000070 bd04                          OUT TCCR0A, R16
000071 e003                          LDI R16, (1<<CS01)|(1<<CS00)
000072 bd05                          OUT TCCR0B, R16
000073 ef09                          LDI R16, 249
000074 bd07                          OUT OCR0A, R16
000075 e002                          LDI R16, (1<<OCIE0A)
000076 9300 006e                     STS TIMSK0, R16
                                 
000078 2777                          CLR MODE
                                 
                                     ; Leer estado inicial de botones tras activar pull-ups
000079 b106                          IN  R16, PINC
00007a 2f20                          MOV R18, R16
00007b 7021                          ANDI R18, (1<<PC0)
00007c 2f52                          MOV  FLAG_PC0, R18
00007d 2f20                          MOV  R18, R16
00007e 7022                          ANDI R18, (1<<PC1)
00007f 2f62                          MOV  FLAG_PC1, R18
000080 2f20                          MOV  R18, R16
000081 7024                          ANDI R18, (1<<PC2)
000082 2f42                          MOV  FLAG_PC2, R18
000083 2f20                          MOV  R18, R16
000084 7028                          ANDI R18, (1<<PC3)
000085 2f32                          MOV  FLAG_PC3, R18
                                 
000086 9478                          SEI
                                 
                                 /****************************************/
                                 MAIN_LOOP:
000087 d007                          RCALL LOGIC_500MS
000088 d01c                          RCALL LOGIC_1S
                                     ; Solo verificar alarma en modos de display
000089 3070                          CPI MODE, 0
00008a f011                          BREQ DO_CHECK_ALARM
00008b 3072                          CPI MODE, 2
00008c f409                          BRNE SKIP_CHECK_ALARM
                                 DO_CHECK_ALARM:
00008d d027                          RCALL CHECK_ALARM
                                 SKIP_CHECK_ALARM:
00008e c089                          RJMP  FSM
                                 
                                 /****************************************/
                                 LOGIC_500MS:
00008f 930f                          PUSH R16
000090 931f                          PUSH R17
                                 
000091 9100 0111                     LDS R16, FLAG_500MS
000093 3001                          CPI R16, 1
000094 f469                          BRNE EXIT_500MS
                                 
000095 2700                          CLR R16
000096 9300 0111                     STS FLAG_500MS, R16
                                 
                                     ; Parpadeo LEDs de segundos (PB4, PB5)
000098 b105                          IN  R16, PORTB
000099 e310                          LDI R17, (1<<PB4)|(1<<PB5)
00009a 2701                          EOR R16, R17
00009b b905                          OUT PORTB, R16
                                 
                                     ; Toggle BLINK_HIDE para parpadeo de dígito activo en config
00009c 9100 011e                     LDS R16, BLINK_HIDE
00009e e011                          LDI R17, 1
00009f 2701                          EOR R16, R17
0000a0 9300 011e                     STS BLINK_HIDE, R16
                                 
                                 EXIT_500MS:
0000a2 911f                          POP R17
0000a3 910f                          POP R16
0000a4 9508                          RET
                                 
                                 /****************************************/
                                 LOGIC_1S:
0000a5 930f                          PUSH R16
                                 
0000a6 9100 0110                     LDS R16, FLAG_1S
0000a8 3001                          CPI R16, 1
0000a9 f449                          BRNE EXIT_1S
                                 
0000aa 2700                          CLR R16
0000ab 9300 0110                     STS FLAG_1S, R16
                                 
                                     ; Reloj avanza en MODE 0 (hora) y MODE 2 (fecha)
0000ad 3070                          CPI MODE, 0
0000ae f019                          BREQ DO_UPDATE
0000af 3072                          CPI MODE, 2
0000b0 f009                          BREQ DO_UPDATE
0000b1 c001                          RJMP EXIT_1S
                                 
                                 DO_UPDATE:
0000b2 d01b                          RCALL UPDATE_CLOCK
                                 
                                 EXIT_1S:
0000b3 910f                          POP R16
0000b4 9508                          RET
                                 
                                 /****************************************/
                                 CHECK_ALARM:
0000b5 930f                          PUSH R16
0000b6 931f                          PUSH R17
                                 
0000b7 9100 010e                     LDS R16, ALARM_ON
0000b9 3001                          CPI R16, 1
0000ba f481                          BRNE EXIT_CHECK_ALARM
                                 
0000bb 9100 0109                     LDS R16, HOURS
0000bd 9110 010d                     LDS R17, ALARM_HOUR
0000bf 1701                          CP  R16, R17
0000c0 f451                          BRNE EXIT_CHECK_ALARM
                                 
0000c1 9100 0108                     LDS R16, MINS
0000c3 9110 010c                     LDS R17, ALARM_MIN
0000c5 1701                          CP  R16, R17
0000c6 f421                          BRNE EXIT_CHECK_ALARM
                                 
                                     ; Hora coincide: activar buzzer y ir a MODE 5
0000c7 e001                          LDI R16, 1
0000c8 9300 010f                     STS BUZZER_ON, R16
0000ca e075                          LDI MODE, 5
                                 
                                 EXIT_CHECK_ALARM:
0000cb 911f                          POP R17
0000cc 910f                          POP R16
0000cd 9508                          RET
                                 
                                 /****************************************/
                                 UPDATE_CLOCK:
0000ce 930f                          PUSH R16
0000cf 931f                          PUSH R17
0000d0 932f                          PUSH R18
                                 
0000d1 9100 0107                     LDS R16, SECS
0000d3 9503                          INC R16
0000d4 330c                          CPI R16, 60
0000d5 f408                          BRSH SEC_OVF
0000d6 c014                          RJMP STORE_SECS
                                 
                                 SEC_OVF:
0000d7 2700                          CLR R16
0000d8 9110 0108                     LDS R17, MINS
0000da 9513                          INC R17
0000db 331c                          CPI R17, 60
0000dc f408                          BRSH MIN_OVF
0000dd c00b                          RJMP STORE_MINS
                                 
                                 MIN_OVF:
0000de 2711                          CLR R17
0000df 9120 0109                     LDS R18, HOURS
0000e1 9523                          INC R18
0000e2 3128                          CPI R18, 24
0000e3 f408                          BRSH HOUR_OVF
0000e4 c002                          RJMP STORE_HOURS
                                 
                                 HOUR_OVF:
0000e5 2722                          CLR R18
0000e6 d00a                          RCALL INC_DAY
                                 
                                 STORE_HOURS:
0000e7 9320 0109                     STS HOURS, R18
                                 STORE_MINS:
0000e9 9310 0108                     STS MINS, R17
                                 STORE_SECS:
0000eb 9300 0107                     STS SECS, R16
                                 
0000ed 912f                          POP R18
0000ee 911f                          POP R17
0000ef 910f                          POP R16
0000f0 9508                          RET
                                 
                                 /****************************************/
                                 INC_DAY:
0000f1 930f                          PUSH R16
0000f2 931f                          PUSH R17
0000f3 93ef                          PUSH ZL
0000f4 93ff                          PUSH ZH
                                 
0000f5 9100 010a                     LDS R16, DAY
0000f7 9503                          INC R16
0000f8 d013                          RCALL GET_MAX_DAY       ; R17 = días máximos del mes actual
0000f9 1701                          CP   R16, R17
0000fa f050                          BRLO STORE_INC_DAY
0000fb f049                          BREQ STORE_INC_DAY      ; último día válido
                                     ; excedió el mes
0000fc e001                          LDI  R16, 1
0000fd 9110 010b                     LDS  R17, MONTH
0000ff 9513                          INC  R17
000100 301d                          CPI  R17, 13
000101 f008                          BRLO STORE_INC_MONTH
000102 e011                          LDI  R17, 1
                                 STORE_INC_MONTH:
000103 9310 010b                     STS  MONTH, R17
                                 STORE_INC_DAY:
000105 9300 010a                     STS  DAY, R16
                                 
000107 91ff                          POP ZH
000108 91ef                          POP ZL
000109 911f                          POP R17
00010a 910f                          POP R16
00010b 9508                          RET
                                 
                                 /****************************************/
                                 ; GET_MAX_DAY: devuelve en R17 los días máximos del mes actual
                                 GET_MAX_DAY:
00010c 93ef                          PUSH ZL
00010d 93ff                          PUSH ZH
00010e 9110 010b                     LDS  R17, MONTH
000110 e0f8                          LDI  ZH, HIGH(tabla_dias_mes << 1)
000111 efe6                          LDI  ZL, LOW(tabla_dias_mes << 1)
000112 0fe1                          ADD  ZL, R17
000113 1df1                          ADC  ZH, R1
000114 9114                          LPM  R17, Z
000115 91ff                          POP  ZH
000116 91ef                          POP  ZL
000117 9508                          RET
                                 
                                 /****************************************/
                                 FSM:
000118 3070                          CPI  MODE, 0
000119 f409                          BRNE FSM_NOT0
00011a c010                          RJMP MODE_HORA
                                 FSM_NOT0:
00011b 3071                          CPI  MODE, 1
00011c f409                          BRNE FSM_NOT1
00011d c015                          RJMP MODE_CONFIG_HORA
                                 FSM_NOT1:
00011e 3072                          CPI  MODE, 2
00011f f409                          BRNE FSM_NOT2
000120 c00e                          RJMP MODE_FECHA
                                 FSM_NOT2:
000121 3073                          CPI  MODE, 3
000122 f409                          BRNE FSM_NOT3
000123 c03d                          RJMP MODE_CONFIG_FECHA
                                 FSM_NOT3:
000124 3074                          CPI  MODE, 4
000125 f409                          BRNE FSM_NOT4
000126 c068                          RJMP MODE_CONFIG_ALARMA
                                 FSM_NOT4:
000127 3075                          CPI  MODE, 5
000128 f409                          BRNE FSM_NOT5
000129 c093                          RJMP MODE_APAGAR_ALARMA
                                 FSM_NOT5:
00012a cf5c                          RJMP MAIN_LOOP
                                 
                                 MODE_HORA:
00012b d215                          RCALL LED_CONFIG_OFF
00012c d21a                          RCALL UPDATE_LED_ALARMA
00012d d0ae                          RCALL DISPLAY_HORA
00012e cf58                          RJMP MAIN_LOOP
                                 
                                 MODE_FECHA:
00012f d211                          RCALL LED_CONFIG_OFF
000130 d216                          RCALL UPDATE_LED_ALARMA
000131 d0bd                          RCALL DISPLAY_FECHA
000132 cf54                          RJMP MAIN_LOOP
                                 
                                 MODE_CONFIG_HORA:
000133 d207                          RCALL LED_CONFIG_ON
000134 9100 0112                     LDS R16, FLAG_BTN_UP
000136 3001                          CPI R16, 1
000137 f459                          BRNE CH_DOWN_HORA
000138 2700                          CLR R16
000139 9300 0112                     STS FLAG_BTN_UP, R16
00013b 9100 011d                     LDS R16, CONFIG_SUB
00013d 3000                          CPI R16, 0
00013e f011                          BREQ CH_UP_HOURS
00013f d16d                          RCALL UP_MINS
000140 c01e                          RJMP SHOW_CH
                                 CH_UP_HOURS:
000141 d154                          RCALL UP_HOURS
000142 c01c                          RJMP SHOW_CH
                                 CH_DOWN_HORA:
000143 9100 0113                     LDS R16, FLAG_BTN_DOWN
000145 3001                          CPI R16, 1
000146 f459                          BRNE CH_SEL_HORA
000147 2700                          CLR R16
000148 9300 0113                     STS FLAG_BTN_DOWN, R16
00014a 9100 011d                     LDS R16, CONFIG_SUB
00014c 3000                          CPI R16, 0
00014d f011                          BREQ CH_DOWN_HOURS
00014e d169                          RCALL DOWN_MINS
00014f c00f                          RJMP SHOW_CH
                                 CH_DOWN_HOURS:
000150 d150                          RCALL DOWN_HOURS
000151 c00d                          RJMP SHOW_CH
                                 CH_SEL_HORA:
000152 9100 0114                     LDS R16, FLAG_BTN_SEL
000154 3001                          CPI R16, 1
000155 f449                          BRNE SHOW_CH
000156 2700                          CLR R16
000157 9300 0114                     STS FLAG_BTN_SEL, R16
000159 9100 011d                     LDS R16, CONFIG_SUB
00015b e011                          LDI R17, 1
00015c 2701                          EOR R16, R17
00015d 9300 011d                     STS CONFIG_SUB, R16
                                 SHOW_CH:
00015f d0a2                          RCALL DISPLAY_CONFIG_HORA
000160 cf26                          RJMP MAIN_LOOP
                                 
                                 MODE_CONFIG_FECHA:
000161 d1d9                          RCALL LED_CONFIG_ON
000162 9100 0112                     LDS R16, FLAG_BTN_UP
000164 3001                          CPI R16, 1
000165 f459                          BRNE CF_DOWN_FECHA
000166 2700                          CLR R16
000167 9300 0112                     STS FLAG_BTN_UP, R16
000169 9100 011d                     LDS R16, CONFIG_SUB
00016b 3000                          CPI R16, 0
00016c f011                          BREQ CF_UP_DAY
00016d d174                          RCALL UP_MONTH
00016e c01e                          RJMP SHOW_CF
                                 CF_UP_DAY:
00016f d154                          RCALL UP_DAY
000170 c01c                          RJMP SHOW_CF
                                 CF_DOWN_FECHA:
000171 9100 0113                     LDS R16, FLAG_BTN_DOWN
000173 3001                          CPI R16, 1
000174 f459                          BRNE CF_SEL_FECHA
000175 2700                          CLR R16
