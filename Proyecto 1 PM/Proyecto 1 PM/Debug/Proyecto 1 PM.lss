000319 9100 010d                     LDS  R16, ALARM_HOUR
00031b 3000                          CPI  R16, 0
00031c f011                          BREQ DAH_UNDER
00031d 950a                          DEC  R16
00031e c001                          RJMP DAH_STORE
                                 DAH_UNDER:
