                                 UP_DAY:
0002c4 930f                          PUSH R16
0002c5 931f                          PUSH R17
0002c6 9100 010a                     LDS  R16, DAY
0002c8 9503                          INC  R16
0002c9 de42                          RCALL GET_MAX_DAY       ; R17 = max días del mes
0002ca 1701                          CP   R16, R17
0002cb f010                          BRLO UD_STORE
0002cc f009                          BREQ UD_STORE           ; último día es válido
0002cd e001                          LDI  R16, 1             ; overflow -> día 1
                                 UD_STORE:
0002ce 9300 010a                     STS  DAY, R16
0002d0 911f                          POP  R17
0002d1 910f                          POP  R16
0002d2 9508                          RET
                                 
                                 DOWN_DAY:
0002d3 930f                          PUSH R16
0002d4 931f                          PUSH R17
0002d5 9100 010a                     LDS  R16, DAY
0002d7 3001                          CPI  R16, 1
0002d8 f011                          BREQ DD_UNDER
0002d9 950a                          DEC  R16
0002da c002                          RJMP DD_STORE
                                 DD_UNDER:
0002db de30                          RCALL GET_MAX_DAY
0002dc 2f01                          MOV  R16, R17
                                 DD_STORE:
0002dd 9300 010a                     STS  DAY, R16
0002df 911f                          POP  R17
0002e0 910f                          POP  R16
0002e1 9508                          RET
                                 
                                 UP_MONTH:
0002e2 930f                          PUSH R16
0002e3 931f                          PUSH R17
0002e4 9100 010b                     LDS  R16, MONTH
0002e6 9503                          INC  R16
0002e7 300d                          CPI  R16, 13
0002e8 f008                          BRLO UMON_CLIP
0002e9 e001                          LDI  R16, 1
                                 UMON_CLIP:
0002ea 9300 010b                     STS  MONTH, R16
                                     ; Recortar día si excede el nuevo mes
0002ec de1f                          RCALL GET_MAX_DAY
0002ed 9100 010a                     LDS  R16, DAY
0002ef 1701                          CP   R16, R17
0002f0 f018                          BRLO UMON_EXIT
0002f1 f011                          BREQ UMON_EXIT
0002f2 9310 010a                     STS  DAY, R17
                                 UMON_EXIT:
0002f4 911f                          POP  R17
0002f5 910f                          POP  R16
0002f6 9508                          RET
                                 
                                 DOWN_MONTH:
0002f7 930f                          PUSH R16
0002f8 931f                          PUSH R17
0002f9 9100 010b                     LDS  R16, MONTH
0002fb 3001                          CPI  R16, 1
0002fc f011                          BREQ DMON_UNDER
0002fd 950a                          DEC  R16
0002fe c001                          RJMP DMON_CLIP
                                 DMON_UNDER:
0002ff e00c                          LDI  R16, 12
                                 DMON_CLIP:
000300 9300 010b                     STS  MONTH, R16
000302 de09                          RCALL GET_MAX_DAY
000303 9100 010a                     LDS  R16, DAY
000305 1701                          CP   R16, R17
000306 f018                          BRLO DMON_EXIT
000307 f011                          BREQ DMON_EXIT
000308 9310 010a                     STS  DAY, R17
                                 DMON_EXIT:
00030a 911f                          POP  R17
00030b 910f                          POP  R16
00030c 9508                          RET
                                 
                                 UP_ALARM_HOURS:
