                                 /****************************************/
                                 ; ---- LEDs indicadores ----
                                 
                                 LED_CONFIG_ON:
00033b 930f                          PUSH R16
00033c b108                          IN   R16, PORTC
00033d 6100                          ORI  R16, (1<<PC4)
00033e b908                          OUT  PORTC, R16
00033f 910f                          POP  R16
000340 9508                          RET
                                 
                                 LED_CONFIG_OFF:
000341 930f                          PUSH R16
000342 b108                          IN   R16, PORTC
000343 7e0f                          ANDI R16, 0xEF
000344 b908                          OUT  PORTC, R16
000345 910f                          POP  R16
000346 9508                          RET
                                 
                                 UPDATE_LED_ALARMA:
000347 930f                          PUSH R16
000348 931f                          PUSH R17
000349 9100 010e                     LDS  R16, ALARM_ON
00034b b118                          IN   R17, PORTC
00034c 3001                          CPI  R16, 1
00034d f411                          BRNE ALA_LED_OFF
00034e 6210                          ORI  R17, (1<<PC5)
00034f c001                          RJMP ALA_LED_STORE
                                 ALA_LED_OFF:
000350 7d1f                          ANDI R17, 0xDF
                                 ALA_LED_STORE:
000351 b918                          OUT  PORTC, R17
000352 911f                          POP  R17
000353 910f                          POP  R16
000354 9508                          RET
                                 
                                 /****************************************/
                                 ; ---- Timer0 ISR (1ms) ----
                                 
                                 TIMER_ISR:
000355 930f                          PUSH R16
000356 b70f                          IN   R16, SREG
000357 930f                          PUSH R16
000358 931f                          PUSH R17
000359 932f                          PUSH R18
00035a 933f                          PUSH R19
00035b 93ef                          PUSH ZL
00035c 93ff                          PUSH ZH
                                 
                                     ; --- Multiplexado ---
00035d b105                          IN   R16, PORTB
00035e 7f00                          ANDI R16, 0b11110000
00035f b905                          OUT  PORTB, R16
                                 
000360 9110 0100                     LDS  R17, DIGIT_INDEX
000362 3010                          CPI  R17, 0
000363 f029                          BREQ T_LOAD0
000364 3011                          CPI  R17, 1
000365 f031                          BREQ T_LOAD1
000366 3012                          CPI  R17, 2
000367 f039                          BREQ T_LOAD2
000368 c009                          RJMP T_LOAD3
                                 
000369 9120 0101                 T_LOAD0: LDS R18, DIG0
00036b c008                          RJMP T_PATTERN
00036c 9120 0102                 T_LOAD1: LDS R18, DIG1
00036e c005                          RJMP T_PATTERN
00036f 9120 0103                 T_LOAD2: LDS R18, DIG2
000371 c002                          RJMP T_PATTERN
000372 9120 0104                 T_LOAD3: LDS R18, DIG3
                                 
                                 T_PATTERN:
000374 e0f8                          LDI ZH, HIGH(tabla_7seg << 1)
000375 eeea                          LDI ZL, LOW(tabla_7seg << 1)
000376 0fe2                          ADD ZL, R18
000377 1df1                          ADC ZH, R1
000378 9104                          LPM R16, Z
                                     ; Preservar PD7 (buzzer) al escribir segmentos
                                     ; Preservar PD7 según BUZZER_ON
000379 9130 010f                     LDS R19, BUZZER_ON
00037b 3031                          CPI R19, 1
00037c f411                          BRNE T_BUZZER_OFF
00037d 6800                          ORI R16, (1<<PD7)
00037e c001                          RJMP T_PORTD_OUT
                                 T_BUZZER_OFF:
00037f 770f                          ANDI R16, 0x7F
                                 T_PORTD_OUT:
000380 b90b                          OUT PORTD, R16
                                 
000381 2f21                          MOV  R18, R17
000382 e031                          LDI  R19, 1
                                 T_SHIFT:
000383 3020                          CPI  R18, 0
000384 f019                          BREQ T_ACT
000385 0f33                          LSL  R19
000386 952a                          DEC  R18
000387 cffb                          RJMP T_SHIFT
                                 T_ACT:
000388 b105                          IN   R16, PORTB
000389 7f00                          ANDI R16, 0b11110000
00038a 2b03                          OR   R16, R19
00038b b905                          OUT  PORTB, R16
                                 
00038c 9110 0100                     LDS  R17, DIGIT_INDEX
00038e 9513                          INC  R17
00038f 3014                          CPI  R17, MAX_DIG
000390 f008                          BRLO T_STORE_IDX
000391 2711                          CLR  R17
                                 T_STORE_IDX:
000392 9310 0100                     STS  DIGIT_INDEX, R17
                                 
                                     ; --- Contador ms ---
000394 9120 0105                     LDS R18, MILISEC_L
