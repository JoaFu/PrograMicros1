                                 /****************************************/
                                 ; ---- Subrutinas de display ----
                                 
                                 DISPLAY_HORA:
0001dc 930f                          PUSH R16
0001dd 931f                          PUSH R17
0001de 9100 0109                     LDS  R16, HOURS
0001e0 d0ae                          RCALL SPLIT_DIGITS
0001e1 9300 0101                     STS  DIG0, R16      ; unidades -> PB0
0001e3 9310 0102                     STS  DIG1, R17      ; decenas  -> PB1
0001e5 9100 0108                     LDS  R16, MINS
0001e7 d0a7                          RCALL SPLIT_DIGITS
0001e8 9310 0103                     STS  DIG2, R17      ; decenas  -> PB2
0001ea 9300 0104                     STS  DIG3, R16      ; unidades -> PB3
0001ec 911f                          POP  R17
0001ed 910f                          POP  R16
0001ee 9508                          RET
                                 
                                 DISPLAY_FECHA:
0001ef 930f                          PUSH R16
0001f0 931f                          PUSH R17
0001f1 9100 010a                     LDS  R16, DAY
0001f3 d09b                          RCALL SPLIT_DIGITS
0001f4 9300 0101                     STS  DIG0, R16      ; unidades -> PB0
0001f6 9310 0102                     STS  DIG1, R17      ; decenas  -> PB1
0001f8 9100 010b                     LDS  R16, MONTH
0001fa d094                          RCALL SPLIT_DIGITS
0001fb 9310 0103                     STS  DIG2, R17      ; decenas  -> PB2
0001fd 9300 0104                     STS  DIG3, R16      ; unidades -> PB3
0001ff 911f                          POP  R17
000200 910f                          POP  R16
000201 9508                          RET
                                 
                                 ; Muestra HH:MM con parpadeo del campo activo (CONFIG_SUB)
                                 DISPLAY_CONFIG_HORA:
000202 930f                          PUSH R16
000203 931f                          PUSH R17
000204 932f                          PUSH R18
                                 
000205 9120 011e                     LDS R18, BLINK_HIDE
                                 
                                     ; Horas (DIG0:DIG1) — parpadea si CONFIG_SUB=0 y BLINK_HIDE=1
000207 9100 011d                     LDS R16, CONFIG_SUB
000209 3000                          CPI R16, 0
00020a f441                          BRNE DCH_SHOW_H
00020b 3021                          CPI R18, 1
00020c f431                          BRNE DCH_SHOW_H
00020d e00a                          LDI R16, 10
00020e 9300 0101                     STS DIG0, R16
000210 9300 0102                     STS DIG1, R16
000212 c007                          RJMP DCH_MINS
                                 DCH_SHOW_H:
000213 9100 0109                     LDS  R16, HOURS
000215 d079                          RCALL SPLIT_DIGITS
000216 9300 0101                     STS  DIG0, R16
000218 9310 0102                     STS  DIG1, R17
                                 
                                 DCH_MINS:
                                     ; Minutos (DIG2:DIG3) — parpadea si CONFIG_SUB=1 y BLINK_HIDE=1
00021a 9100 011d                     LDS R16, CONFIG_SUB
00021c 3001                          CPI R16, 1
00021d f441                          BRNE DCH_SHOW_M
00021e 3021                          CPI R18, 1
00021f f431                          BRNE DCH_SHOW_M
000220 e00a                          LDI R16, 10
000221 9300 0103                     STS DIG2, R16
000223 9300 0104                     STS DIG3, R16
000225 c007                          RJMP DCH_EXIT
                                 DCH_SHOW_M:
000226 9100 0108                     LDS  R16, MINS
000228 d066                          RCALL SPLIT_DIGITS
000229 9310 0103                     STS  DIG2, R17
00022b 9300 0104                     STS  DIG3, R16
                                 
                                 DCH_EXIT:
00022d 912f                          POP R18
00022e 911f                          POP R17
00022f 910f                          POP R16
000230 9508                          RET
                                 
